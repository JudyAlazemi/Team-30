document.addEventListener("DOMContentLoaded", () => {
  const searchInput = document.getElementById("productSearch");
  const categoryFilter = document.getElementById("categoryFilter");
  const priceFilter = document.getElementById("priceFilter");
  const categoryButtons = []; 
  let activeButtonCategory = "all";

  function getProductCards() {
    return document.querySelectorAll(".product-card");
  }

  function getPriceValue(priceText) {
    return parseFloat(priceText.replace("£", "").trim()) || 0;
  }

  function matchesPrice(price, range) {
    if (range === "all") return true;
    if (range === "0-10") return price >= 0 && price <= 10;
    if (range === "10-20") return price > 10 && price <= 20;
    if (range === "20-50") return price > 20 && price <= 50;
    if (range === "50+") return price > 50;
    return true;
  }

  function filterProducts() {
    const productCards = getProductCards();
    const searchValue = searchInput ? searchInput.value.toLowerCase().trim() : "";
    const selectedDropdownCategory = categoryFilter ? categoryFilter.value : "all";
    const selectedPrice = priceFilter ? priceFilter.value : "all";

    const finalCategory =
      selectedDropdownCategory !== "all"
        ? selectedDropdownCategory
        : activeButtonCategory;

    productCards.forEach((card) => {
      const name =
        card.querySelector("h3")?.textContent.toLowerCase().trim() || "";
      const category = card.dataset.category || "";
      const priceText =
        card.querySelector(".product-price")?.textContent.trim() || "£0";
      const price = getPriceValue(priceText);

      const matchesName = searchValue === "" || name.startsWith(searchValue);
      const matchesCategory =
        finalCategory === "all" || category === finalCategory;
      const priceMatches = matchesPrice(price, selectedPrice);

      if (matchesName && matchesCategory && priceMatches) {
        card.style.display = "";
      } else {
        card.style.display = "none";
      }
    });
  }

  categoryButtons.forEach((button) => {
    button.addEventListener("click", () => {
      categoryButtons.forEach((btn) => btn.classList.remove("active"));
      button.classList.add("active");

      activeButtonCategory = button.dataset.category || "all";

      if (categoryFilter) {
        categoryFilter.value = "all";
      }

      filterProducts();
    });
  });

  if (searchInput) {
    searchInput.addEventListener("input", filterProducts);
  }

  if (categoryFilter) {
    categoryFilter.addEventListener("change", () => {
      categoryButtons.forEach((btn) => btn.classList.remove("active"));

      if (categoryFilter.value === "all") {
        const allBtn = document.querySelector('.category-btn[data-category="all"]');
        if (allBtn) allBtn.classList.add("active");
        activeButtonCategory = "all";
      }

      filterProducts();
    });
  }

  if (priceFilter) {
    priceFilter.addEventListener("change", filterProducts);
  }

  filterProducts();
});
